# =============================================================
# Quedamos — variables de entorno
# Copiá este archivo a .env.local y completá con valores reales.
# NUNCA commitees .env.local (tiene secrets).
# =============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Settings → API → service_role secret

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=quedamos-uploads
R2_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# --- Worker / app ---
# Secreto que el upload usa para invocar /api/process-job. Generalo con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QUEDAMOS_WORKER_SECRET=<64 chars hex>

# Base URL pública. En local: http://localhost:3000.
# En Vercel: la URL del deploy (ej: https://quedamos.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000
